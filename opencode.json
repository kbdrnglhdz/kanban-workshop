{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow"
    },
    "read": "allow",
    "grep": "allow"
  },
  "mcp": {
  "context7": {
    "type": "remote",
    "url": "https://mcp.context7.com/mcp"
  },
  "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "TOKEN"
      }
    }
}
}
